# ==============================================================================
# Environment configuration template.
# Copy to .env for local development: cp .env.example .env
# NEVER commit a real .env file. It is excluded via .gitignore.
# In CI/CD and production, inject these as secrets (GitHub Actions Secrets,
# Kubernetes Secrets, or a secrets manager) — never as plain environment
# variables baked into the image.
# ==============================================================================

NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
# Runtime connection. This role should only have CRUD permissions.
PGHOST=localhost
PGPORT=5432
PGDATABASE=taskapi
PGUSER=taskapi_app
PGPASSWORD=change_me_local_only

# --- JWT ---
# Generate with: openssl rand -base64 64
# Minimum 256 bits of entropy. Rotate periodically. Never reuse across envs.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=15m

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Shared store for rate-limit counters. Required in production.
# Example local value when using Docker Compose: redis://localhost:6379
RATE_LIMIT_REDIS_URL=

# Prometheus scrape endpoint at GET /metrics.
METRICS_ENABLED=true

# Number of trusted reverse-proxy hops. Keep 0 when connecting directly.
# Typical Kubernetes ingress deployment: 1.
TRUST_PROXY_HOPS=0

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
