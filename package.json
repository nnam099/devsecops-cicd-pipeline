{
  "name": "taskapi",
  "version": "1.0.0",
  "description": "Clean Architecture Node.js/Express Task Management API - DevSecOps thesis reference application",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node src/infrastructure/database/migrate.js",
    "test": "jest --coverage",
    "test:unit": "jest --config jest.unit.config.js tests/unit",
    "test:integration": "jest --config jest.config.js tests/integration --runInBand",
    "lint": "eslint src tests --max-warnings=0",
    "lint:fix": "eslint src tests --fix"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0"
  },
  "devDependencies": {
    "eslint": "^10.7.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-security": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
